# Default: Google's Gemini free tier. Create a key at https://aistudio.google.com/app/apikey
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional paid OpenAI fallback: set LLM_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Medium no longer issues new integration tokens. This only works with an
# existing token. Leave both values empty if you will copy drafts manually.
MEDIUM_ACCESS_TOKEN=
MEDIUM_PUBLICATION_ID=
MEDIUM_PUBLICATION_SLUG=devops-diaries-hub
MEDIUM_PUBLICATION_URL=https://medium.com/devops-diaries-hub
MEDIUM_PUBLICATION_NAME=DevOps-Diaries-Hub

BOT_AUTHOR_NAME=Your Name
BOT_TIMEZONE=America/Chicago
BOT_DAILY_HOUR=8
BOT_MIN_WORDS=800
BOT_MAX_WORDS=1600
